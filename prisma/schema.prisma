generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["views"]
}

datasource db {
  provider = "mysql"
}

model users {
  id         Int      @id @default(autoincrement())
  email      String   @unique(map: "Users_email_key")
  phone      String?  @db.VarChar(255)
  name       String?
  created_at DateTime @default(now())
  password   String?
  role_id    Int?
}

model event_type {
  eventId     Int           @id @default(autoincrement())
  eventType   String        @unique(map: "Event_Type_eventType_key")
  description String?
  eventmaster eventmaster[]
}

model eventmaster {
  id             Int             @id @default(autoincrement())
  eventId        Int
  eventTimestamp DateTime
  value          String?
  anprevent      anprevent?
  event_type     event_type      @relation(fields: [eventId], references: [eventId], map: "EventMaster_eventId_fkey")
  intrusionevent intrusionevent?
  vehicle_event  vehicle_event?

  @@index([eventId], map: "EventMaster_eventId_idx")
  @@index([eventTimestamp], map: "EventMaster_eventTimestamp_idx")
}

model vehicle_cycle {
  cycle_date      DateTime  @db.Date
  vehicleNo       String    @db.VarChar(50)
  entry_time      DateTime? @db.DateTime(0)
  weight_time     DateTime? @db.DateTime(0)
  exit_time       DateTime? @db.DateTime(0)
  weight          Float?
  entry_imageId   Int?
  weight_imageId  Int?
  exit_imageId    Int?
  created_at      DateTime? @default(now()) @db.Timestamp(0)
  total_minutes   Int?
  final_vehicleNo String?   @db.VarChar(255)
  final_weight    Float?
  matched_wb_id   Int?
  info_anpr       String?   @db.VarChar(400)
  info_entryexit  String?   @db.VarChar(400)

  @@id([cycle_date, vehicleNo])
  @@index([vehicleNo], map: "idx_vehicle")
  @@index([weight_time], map: "idx_weight_time")
  @@index([matched_wb_id], map: "idx_matched_wb_id")
}

model anprevent {
  id                Int                 @id @default(autoincrement())
  eventMasterId     Int                 @unique(map: "AnprEvent_eventMasterId_key")
  vehicleNo         String
  updated_vehicleNo String?             @db.VarChar(20)
  vehicleWt         Float?
  updated_vehicleWt Float?
  imageId           Int?
  created_at        DateTime?           @default(now()) @db.Timestamp(0)
  updated_at        DateTime?           @default(now()) @db.Timestamp(0)
  flag              Boolean             @default(false)
  eventmaster       eventmaster         @relation(fields: [eventMasterId], references: [id], onDelete: Cascade, map: "AnprEvent_eventMasterId_fkey")
  anpr_images       weighbridge_images? @relation(fields: [imageId], references: [id], map: "fk_anpr_images")

  @@index([imageId], map: "fk_anpr_images")
}

model intrusionevent {
  id            Int                     @id @default(autoincrement())
  eventMasterId Int                     @unique(map: "IntrusionEvent_eventMasterId_key")
  location      String
  severity      intrusionevent_severity @default(medium)
  description   String
  eventmaster   eventmaster             @relation(fields: [eventMasterId], references: [id], onDelete: Cascade, map: "IntrusionEvent_eventMasterId_fkey")
}

model curation_state {
  id            Int       @id @default(1)
  last_event_id Int?      @default(0)
  last_run_l1   DateTime? @default(now()) @db.Timestamp(0)
  last_run_l2   DateTime? @db.Timestamp(0)
}

model correction_state {
  id            Int       @id @default(1)
  last_event_id Int?      @default(0)
  last_run      DateTime? @default(now()) @db.Timestamp(0)
}

model device_logs {
  id         Int                 @id @default(autoincrement())
  ip         String?             @db.VarChar(50)
  status     device_logs_status?
  event_time DateTime?           @db.DateTime(0)
}

model downtime {
  id            Int            @id @default(autoincrement())
  ip            String?        @db.VarChar(50)
  down_start    DateTime?      @db.DateTime(0)
  down_end      DateTime?      @db.DateTime(0)
  device_master device_master? @relation(fields: [ip], references: [ip], onDelete: Restrict, onUpdate: NoAction, map: "fk_downtime_ip")

  @@index([ip], map: "fk_downtime_ip")
}

model entry_exit_images {
  id            Int             @id @default(autoincrement())
  truckImage    Bytes?          @db.MediumBlob
  plateImage    Bytes?          @db.MediumBlob
  created_at    DateTime?       @default(now()) @db.Timestamp(0)
  vehicle_event vehicle_event[]
}

model vehicle_event {
  id                Int                @id @default(autoincrement())
  eventMasterId     Int                @unique(map: "AnprEvent_eventMasterId_key")
  vehicleNo         String?
  updated_vehicleNo String?            @db.VarChar(20)
  imageId           Int?
  created_at        DateTime?          @default(now()) @db.Timestamp(0)
  updated_at        DateTime?          @default(now()) @db.Timestamp(0)
  movement          String?            @db.VarChar(255)
  flag              Boolean            @default(false)
  eventmaster       eventmaster        @relation(fields: [eventMasterId], references: [id], onDelete: Cascade, map: "vehicle_event_ibfk_1")
  entry_exit_images entry_exit_images? @relation(fields: [imageId], references: [id], map: "vehicle_event_ibfk_2")

  @@index([imageId], map: "fk_anpr_images")
}

model weighbridge_images {
  id         Int         @id @default(autoincrement())
  truckImage Bytes?      @db.MediumBlob
  plateImage Bytes?      @db.MediumBlob
  created_at DateTime?   @default(now()) @db.Timestamp(0)
  anprevent  anprevent[]
}

model weighbridge_records {
  id               Int       @id @default(autoincrement())
  vehicle_no       String?   @db.VarChar(20)
  gross            Int?
  tare             Int?
  net              Int?
  bags             Int?
  gross_timestamp  DateTime? @db.DateTime(0)
  tare_timestamp   DateTime? @db.DateTime(0)
  system_timestamp DateTime? @db.DateTime(0)
  raw_data         String?   @db.LongText
  created_at       DateTime? @default(now()) @db.Timestamp(0)

  @@unique([vehicle_no, gross, tare, gross_timestamp, tare_timestamp], map: "unique_weigh")
  @@index([gross_timestamp], map: "idx_gross_time")
  @@index([tare_timestamp], map: "idx_tare_time")
  @@index([vehicle_no], map: "idx_vehicle_no")
}

model curated_vehicle_cycle {
  id               Int       @id @default(autoincrement())
  vehicleNo        String?   @db.VarChar(50)
  event_date       DateTime? @db.Date
  entry_time       DateTime? @db.DateTime(0)
  exit_time        DateTime? @db.DateTime(0)
  entry_imageId    Int?
  exit_imageId     Int?
  tare_wt          Float?
  tare_wt_time     DateTime? @db.DateTime(0)
  gross_wt         Float?
  gross_wt_time    DateTime? @db.DateTime(0)
  net_wt           Float?
  unique_cycle_key String?   @unique(map: "unique_cycle_key") @db.VarChar(100)
  created_at       DateTime? @default(now()) @db.Timestamp(0)
}

model intrusion_event {
  id             Int       @id @default(autoincrement())
  intrusion_type String    @db.VarChar(100)
  description    String?   @db.Text
  image          Bytes?    @db.MediumBlob
  created_at     DateTime? @default(now()) @db.DateTime(0)
  updated_at     DateTime? @default(now()) @db.DateTime(0)
  intrusion_dt   DateTime? @db.DateTime(0)
}

model role_master {
  id   Int
  role String

  @@id([id, role])
}

model device_master {
  id       Int        @id @default(autoincrement())
  ip       String     @unique(map: "ip_2") @db.VarChar(50)
  desc     String?    @db.VarChar(99)
  downtime downtime[]

  @@index([ip], map: "ip")
}

model loading_truck_images {
  id                    Int                     @id @default(autoincrement())
  truck_img             Bytes?
  plate_img             Bytes?
  loading_truck_records loading_truck_records[]
}

model loading_truck_records {
  id                   Int                   @id @default(autoincrement())
  truck_img_id         Int?
  timestamp            String?               @db.VarChar(50)
  vehicle_no           String?               @db.VarChar(50)
  updated_vehicle_no   String?               @db.VarChar(50)
  created_at           DateTime?             @default(now()) @db.Timestamp(0)
  updated_at           DateTime?             @default(now()) @db.Timestamp(0)
  flag                 Int?                  @default(0) @db.TinyInt
  loading_truck_images loading_truck_images? @relation(fields: [truck_img_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "loading_truck_records_ibfk_1")

  @@index([truck_img_id], map: "truck_img_id")
}

view vw_danpr {
  dt   DateTime? @db.Date
  vno  String?   @db.VarChar(20)
  evt  String?   @db.Text
  wts  String?   @db.Text
  imgs String?   @db.Text
}

view vw_entryexit {
  dt   DateTime? @db.Date
  vno  String?   @db.VarChar(20)
  evt  String?   @db.Text
  et   String?   @db.Text
  imgs String?   @db.Text
}

view v_alldata {
  entryCnt  BigInt @default(0)
  exitCnt   BigInt @default(0)
  loadCnt   BigInt @default(0)
  unloadCnt BigInt @default(0)
}

view v_chartdata {
  date      DateTime? @db.Date
  entryCnt  Decimal?  @db.Decimal(23, 0)
  exitCnt   Decimal?  @db.Decimal(23, 0)
  loadCnt   Decimal?  @db.Decimal(23, 0)
  unloadCnt Decimal?  @db.Decimal(23, 0)
}

view v_day {
  entryCnt  BigInt @default(0)
  exitCnt   BigInt @default(0)
  loadCnt   BigInt @default(0)
  unloadCnt BigInt @default(0)
}

view v_mnthdata {
  entryCnt  BigInt @default(0)
  exitCnt   BigInt @default(0)
  loadCnt   BigInt @default(0)
  unloadCnt BigInt @default(0)
}

view v_report {
  event_date    DateTime? @db.Date
  vehicleNo     String?   @db.VarChar(20)
  entry_time    DateTime?
  exit_time     DateTime?
  tare_wt       Int?
  gross_wt      Int?
  net_wt        Int?
  tare_wt_time  DateTime? @db.DateTime(0)
  gross_wt_time DateTime? @db.DateTime(0)
}

view v_report_old {
  vehicleNo     String    @db.VarChar(50)
  entry_time    DateTime? @db.DateTime(0)
  exit_time     DateTime? @db.DateTime(0)
  tear_wt_time  DateTime? @db.DateTime(0)
  gross_wt_time DateTime? @db.DateTime(0)
  tear_wt       Float?
  gross_wt      Float?
  net_wt        Float?
  event_date    DateTime? @db.Date
}

view v_bagsCnt {
  dt        DateTime? @db.Date
  entryCnt  BigInt    @default(0)
  exitCnt   BigInt    @default(0)
  loadCnt   BigInt    @default(0)
  unloadCnt BigInt    @default(0)
}

enum intrusionevent_severity {
  low
  medium
  high
  critical
}

enum device_logs_status {
  UP
  DOWN
}
